# AgentFlow Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=production

# Database
DATABASE_PATH=./data/agentflow.db

# Logging
LOG_LEVEL=info          # debug, info, warn, error
LOG_FILE=./logs/agentflow.log

# Security
OPENCLAW_ADMIN_TOKEN=change-me-to-secure-token-here
JWT_SECRET=change-me-to-random-secret

# OpenClaw Integration
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_WS_URL=ws://localhost:18789

# Telegram Integration (Optional)
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=716239770
TELEGRAM_NOTIFICATIONS_ENABLED=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000    # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# WebSocket
WS_HEARTBEAT_INTERVAL_MS=30000
WS_MAX_CONNECTIONS=100

# Task Processing
TASK_QUEUE_CONCURRENCY=4
TASK_TIMEOUT_MS=3600000         # 1 hour
TASK_RETRY_ATTEMPTS=3
TASK_RETRY_DELAY_MS=5000

# Scheduled Tasks
SCHEDULER_CHECK_INTERVAL_MS=60000    # 1 minute
SCHEDULER_ENABLED=true

# Analytics
ANALYTICS_RETENTION_DAYS=180
ANALYTICS_AGGREGATION_ENABLED=true

# Backup
BACKUP_ENABLED=false
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
BACKUP_DESTINATION=./backups

# Performance
MAX_TASK_HISTORY=10000
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300

# Features
FEATURES_WEBSOCKET_ENABLED=true
FEATURES_SCHEDULED_TASKS_ENABLED=true
FEATURES_OUTCOME_TRACKING_ENABLED=true
FEATURES_TELEGRAM_INTEGRATION_ENABLED=false

# Development
DEV_AUTO_SEED_DATA=false
DEV_CORS_ENABLED=true
DEV_DEBUG_MODE=false
