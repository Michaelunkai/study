              "readOnly": false,
              "removed": false
            },
            {
              "id": "docUrl",
              "displayName": "Resume Doc URL",
              "required": false,
              "defaultMatch": false,
              "display": true,
              "type": "string",
              "readOnly": false,
              "removed": false
            },
            {
              "id": "jobUrl",
              "displayName": "Job URL",
              "required": false,
              "defaultMatch": false,
              "display": true,
              "type": "string",
              "readOnly": false,
              "removed": false
            },
            {
              "id": "status",
              "displayName": "Status",
              "required": false,
              "defaultMatch": false,
              "display": true,
              "type": "string",
              "readOnly": false,
              "removed": false
            }
          ]
        },
        "options": {}
      },
      "id": "log-to-sheets",
      "name": "Part 8: Log to Google Sheets Database",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [2250, 250],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "4",
          "name": "Google Sheets OAuth2"
        }
      }
    },
    {
      "parameters": {
        "filePath": "=F:\\study\\AI_ML\\AI_and_Machine_Learning\\Artificial_Intelligence\\ai-job-bot\\resume-data.json"
      },
      "id": "read-resume-data",
      "name": "Read Resume Data",
      "type": "n8n-nodes-base.readBinaryFile",
      "typeVersion": 1,
      "position": [750, 500]
    },
    {
      "parameters": {
        "operation": "aggregateItems",
        "aggregate": "aggregateAllItemData",
        "options": {}
      },
      "id": "summarize-results",
      "name": "Summarize Results",
      "type": "n8n-nodes-base.aggregate",
      "typeVersion": 1,
      "position": [2500, 250]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.telegram.org/bot{{ $env.TELEGRAM_BOT_TOKEN }}/sendMessage",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "chat_id",
              "value": "={{ $env.TELEGRAM_CHAT_ID }}"
            },
            {
              "name": "text",
              "value": "=✅ AI Job Bot completed!\n\n📊 Jobs processed: {{ $json.totalJobs }}\n✅ Relevant jobs found: {{ $json.relevantJobs }}\n📝 Resumes created: {{ $json.resumesGenerated }}\n\n🔗 Check Google Drive for resumes\n📊 View Google Sheets for full log"
            }
          ]
        },
        "options": {}
      },
      "id": "send-telegram-notification",
      "name": "Send Telegram Notification (Optional)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2750, 250],
      "disabled": false
    }
  ],
