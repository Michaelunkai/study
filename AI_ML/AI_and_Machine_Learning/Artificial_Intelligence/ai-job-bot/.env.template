# AI Job Application Bot - Environment Variables
# Copy this file to .env and fill in your actual values

# ========================================
# OpenAI Configuration
# ========================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Model to use for job filtering and resume generation
OPENAI_MODEL=gpt-4o

# ========================================
# Apify Configuration
# ========================================
# Get your token from: https://console.apify.com/account/integrations
APIFY_API_TOKEN=apify_api_...

# LinkedIn Job Scraper Actor ID (default: apify/linkedin-jobs-scraper)
APIFY_ACTOR_ID=apify/linkedin-jobs-scraper

# ========================================
# Google Workspace Configuration
# ========================================
# Service Account JSON (from Google Cloud Console)
# https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Folder ID where resumes will be created (get from Google Drive URL)
GOOGLE_DRIVE_FOLDER_ID=

# Google Sheets ID for job tracking database
GOOGLE_SHEETS_ID=

# ========================================
# Job Search Parameters
# ========================================
# Comma-separated job titles/keywords to search for
JOB_KEYWORDS=AI Engineer, ML Engineer, Machine Learning Engineer, Python Developer, DevOps Engineer, Data Scientist, Backend Engineer, Cloud Engineer

# Location preferences (comma-separated)
JOB_LOCATION=Israel, Remote, Tel Aviv, Haifa, Jerusalem

# Only show remote jobs (true/false)
JOB_REMOTE_ONLY=true

# Experience level (entry, mid, senior, lead)
JOB_EXPERIENCE_LEVEL=mid,senior

# Maximum number of jobs to scrape per run
MAX_JOBS_PER_RUN=50

# ========================================
# AI Filtering Configuration
# ========================================
# Minimum relevance score (0-10) to apply (7 = 70% match)
MIN_RELEVANCE_SCORE=7

# Skills that MUST be in job description (comma-separated)
REQUIRED_SKILLS=Python, AI, Machine Learning

# Skills that are nice to have (comma-separated)
PREFERRED_SKILLS=Kubernetes, Docker, AWS, Azure, TensorFlow, PyTorch, FastAPI, Django, Flask

# Industries to prioritize (comma-separated)
PREFERRED_INDUSTRIES=Technology, AI, SaaS, Cloud, Startup, Fintech

# ========================================
# Resume Customization
# ========================================
# Your current job title
CURRENT_TITLE=AI Engineer

# Years of experience
YEARS_OF_EXPERIENCE=5

# Resume tone (professional, technical, creative, concise)
RESUME_TONE=professional

# Resume length (short=1 page, medium=1-2 pages, detailed=2+ pages)
RESUME_LENGTH=short

# ========================================
# Automation Schedule
# ========================================
# How often to run (daily, weekly, manual)
RUN_SCHEDULE=daily

# Time to run (24h format: 09:00, 18:00)
RUN_TIME=09:00

# Timezone
TIMEZONE=Asia/Jerusalem

# ========================================
# Notification Settings
# ========================================
# Email for notifications (optional)
NOTIFICATION_EMAIL=

# Telegram bot token for notifications (optional)
TELEGRAM_BOT_TOKEN=

# Telegram chat ID (optional)
TELEGRAM_CHAT_ID=

# ========================================
# Advanced Settings
# ========================================
# Enable debug logging (true/false)
DEBUG=false

# Maximum API retries on failure
MAX_RETRIES=3

# Delay between API calls (milliseconds)
API_DELAY_MS=1000

# Save raw Apify results for debugging (true/false)
SAVE_RAW_DATA=false
