<Window x:Class="GameLauncherPro.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Game Launcher Pro" Height="400" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1e1e1e">
    <Grid>
        <StackPanel Margin="30" VerticalAlignment="Center">
            <TextBlock Text="🎮 Game Launcher Pro" 
                      FontSize="32" 
                      FontWeight="Bold" 
                      Foreground="#00d9ff"
                      TextAlignment="Center"
                      Margin="0,0,0,20"/>
            
            <TextBlock Text="Version 1.0.0" 
                      FontSize="16" 
                      Foreground="#888"
                      TextAlignment="Center"
                      Margin="0,0,0,30"/>
            
            <TextBlock TextWrapping="Wrap" 
                      FontSize="14" 
                      Foreground="White"
                      TextAlignment="Center"
                      Margin="0,0,0,20">
                A professional game library manager and launcher
                <LineBreak/>
                Built for speed and simplicity
            </TextBlock>
            
            <Border Background="#2d2d30" 
                   CornerRadius="8" 
                   Padding="20"
                   Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Features:" 
                              FontWeight="Bold" 
                              Foreground="#00d9ff"
                              Margin="0,0,0,10"/>
                    <TextBlock Foreground="White" FontSize="12">
                        ✓ Auto-scan all drives for games<LineBreak/>
                        ✓ One-click game launching<LineBreak/>
                        ✓ Search and filter<LineBreak/>
                        ✓ Play statistics tracking<LineBreak/>
                        ✓ CLI support for automation
                    </TextBlock>
                </StackPanel>
            </Border>
            
            <TextBlock TextAlignment="Center" 
                      Foreground="#888" 
                      FontSize="11">
                Built with .NET 9.0 and WPF
                <LineBreak/>
                © 2026 Game Launcher Pro
            </TextBlock>
            
            <Button Content="Close" 
                   Width="120" 
                   Height="35" 
                   Margin="0,20,0,0"
                   Click="Close_Click"
                   HorizontalAlignment="Center"
                   Background="#0e639c"
                   Foreground="White"
                   BorderThickness="0"
                   FontSize="14"
                   Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
