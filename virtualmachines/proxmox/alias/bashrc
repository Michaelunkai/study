alias plex="vzdump 101 --mode snapshot --compress lzo --storage local && qm stop 101 && qm destroy 101 && qmrestore /var/lib/vz/dump/$(ls -Art /var/lib/vz/dump/ | grep 'vzdump-qemu-101' | tail -n 1) 101"
alias backup="cd /var/lib/vz/dump && docker build -t michadockermisha/backup:proxdump . && docker push michadockermisha/backup:proxdump && cd ../template/iso && docker build -t michadockermisha/backup:proxiso . && docker push michadockermisha/backup:proxiso && docker stop $(docker ps -aq) || true && docker rm $(docker ps -aq) || true && ( [ "$(docker ps -q)" ] || docker rmi $(docker images -q) || true ) && ( [ "$(docker images -q)" ] || docker system prune -a --volumes --force ) && docker network prune --force || true"
alias ansibleupdate='cd /etc/ansible/playbooks/ && ansible-playbook update.yml --extra-vars "ansible_become_pass=123456"'
