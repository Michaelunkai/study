# PowerShell / Windows transient files
*.log
*.tmp
*.bak
*.bak-*
*.bak.*
*.old
*.orig
*.swp
*.swo

# Python/editor caches if helper tooling is added later
__pycache__/
*.pyc
.venv/
venv/
.env
.env.*

# Build/output caches
bin/
obj/
dist/
build/

# Local generated verification output
verification/*.local.txt
verification/*.local.json

# Runtime state stays local, but wrapper scripts under runtime/qbit-fitgirl-auto-install are source files.
runtime/fitlauncher-zero-download-guardian/*
!runtime/fitlauncher-zero-download-guardian/.gitkeep

# Never commit secrets or local qBittorrent config backups
*qBittorrent.ini*
*.key
*.pem
*.pfx
